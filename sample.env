# Integration test credentials for run_integration_tests.sh
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Required
HSBT_TEST_HOST=u000001.your-storagebox.de
HSBT_TEST_USER=u000001
HSBT_TEST_PASSWORD=yourpassword

# Optional: SSH port (default: 23)
#HSBT_TEST_SSH_PORT=23

# Optional: persistent directory for the test SSH keypair.
# When set, the key is deployed once and reused on subsequent runs.
# When unset, a fresh temp dir is used and the key is redeployed every run.
#HSBT_TEST_KEY_DIR=~/.config/hsbt/integration-keys
